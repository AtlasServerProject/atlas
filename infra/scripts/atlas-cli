#!/bin/bash

set -Eeuo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

COMMAND="${1:-}"

if [ "$#" -gt 0 ]; then
    shift
fi

ADMIN_SOCKET="${ATLAS_ADMIN_SOCKET:-/opt/atlas/server/fabric/atlas-admin.sock}"

run_admin_command() {
    local command="$1"

    if [ ! -S "$ADMIN_SOCKET" ]; then
        echo "Console Atlas indisponível em $ADMIN_SOCKET."
        return 1
    fi

    printf '%s\n' "$command" | nc -N -U "$ADMIN_SOCKET"
}

case "$COMMAND" in

    install)
        "$SCRIPT_DIR/install.sh"
        ;;

    doctor)
        "$SCRIPT_DIR/doctor.sh"
        ;;

    backup)
        "$SCRIPT_DIR/backup.sh"
        ;;

    restore)
        "$SCRIPT_DIR/restore.sh"
        ;;

    update)
        "$SCRIPT_DIR/update.sh"
        ;;
    migrate)
        "$SCRIPT_DIR/migrate.sh"
        ;;

    start)
        sudo systemctl start atlas
        ;;

    stop)
        sudo systemctl stop atlas
        ;;

    restart)
        sudo systemctl restart atlas
        ;;

    status)
        sudo systemctl status atlas
        ;;

    logs)
        journalctl -u atlas -f
        ;;

    console)
        if ! command -v nc >/dev/null 2>&1; then
            echo "netcat não está instalado."
            exit 1
        fi

        if [ ! -S "$ADMIN_SOCKET" ]; then
            echo "Console Atlas indisponível em $ADMIN_SOCKET."
            exit 1
        fi

        echo "Console administrativo Atlas. Use 'exit' para sair."
        while IFS= read -r -p "atlas> " admin_command; do
            case "$admin_command" in
                exit|quit)
                    break
                    ;;
                "")
                    continue
                    ;;
                *)
                    run_admin_command "$admin_command"
                    ;;
            esac
        done
        ;;

    exec)
        if [ "$#" -eq 0 ]; then
            echo "Uso: atlas-cli exec <comando>"
            exit 1
        fi

        run_admin_command "$*"
        ;;

    *)
        echo "Atlas CLI"
        echo
        echo "Uso:"
        echo "  atlas-cli install"
        echo "  atlas-cli doctor"
        echo "  atlas-cli start"
        echo "  atlas-cli stop"
        echo "  atlas-cli restart"
        echo "  atlas-cli status"
        echo "  atlas-cli logs"
        echo "  atlas-cli console"
        echo "  atlas-cli exec <comando>"
        echo "  atlas-cli migrate"
        ;;
esac
